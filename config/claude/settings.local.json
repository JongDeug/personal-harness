{
  "permissions": {
    "allow": [
      "*"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/channels/telegram/scripts/telegram-prompt-hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_telegram_telegram__reply",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/channels/telegram/scripts/telegram-reply-format-hook.sh"
          }
        ]
      }
    ]
  }
}
