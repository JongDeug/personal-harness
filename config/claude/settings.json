{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/skills/sync-readme/scripts/detect-structure-change.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [[ \"$(uname)\" == \"Darwin\" ]]; then B=~/Documents; else B=~/workspace; fi; bash \"$B/personal-harness/config/claude/hooks/notify.sh\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [[ \"$(uname)\" == \"Darwin\" ]]; then B=~/Documents; else B=~/workspace; fi; NOTIFY_ONLY_BG=1 NOTIFY_DEFAULT_MSG=\"✅ 작업 완료\" bash \"$B/personal-harness/config/claude/hooks/notify.sh\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cat > /tmp/claude-rate-limits.json"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "telegram@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "frontend-slides@frontend-slides": true,
    "claude-md-management@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "frontend-design@claude-plugins-official": true,
    "humanize-korean@im-not-ai": true
  },
  "extraKnownMarketplaces": {
    "frontend-slides": {
      "source": {
        "source": "github",
        "repo": "zarazhangrui/frontend-slides"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "im-not-ai": {
      "source": {
        "source": "github",
        "repo": "epoko77-ai/im-not-ai"
      }
    }
  },
  "language": "Korean",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
