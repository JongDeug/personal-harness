{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/skills/sync-readme/scripts/detect-structure-change.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if [[ \"$(uname)\" == \"Darwin\" ]]; then B=~/Documents; else B=~/workspace; fi; bash \"$B/personal-harness/config/claude/hooks/notify.sh\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true,
  "language": "Korean",
  "voiceEnabled": true,
  "showThinkingSummaries": true,
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "cat > /tmp/claude-rate-limits.json"
  }
}
